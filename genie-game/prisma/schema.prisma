generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id          Int      @id @default(autoincrement())
  countryName String   @unique @db.VarChar(256)
  currencyId  Int
  Currency    Currency @relation(fields: [currencyId], references: [id])
}

model HistoricalRate {
  countryId Int
  year      Int
  rate      Float
  country   Currency @relation(fields: [countryId], references: [id])

  @@id([countryId, year])
}

model Currency {
  id              Int              @id @default(autoincrement())
  countryCode     String           @unique @db.VarChar(256)
  countryName     String?          @db.VarChar(256)
  currencyName    String?          @db.VarChar(256)
  Country         Country[]
  historicalRates HistoricalRate[]
}
